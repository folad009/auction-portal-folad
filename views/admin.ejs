<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head', { title: 'Admin console', metaDescription: 'Manage auction rounds, assets, approvals, and images.' }) %>
  </head>
  <body class="flex min-h-screen flex-col bg-slate-100 font-sans text-slate-800 antialiased">
    <%- include('partials/nav-admin') %>

    <main class="flex-1">
      <div class="border-b border-slate-200 bg-gradient-to-r from-indigo-600 via-violet-600 to-fuchsia-600 px-4 py-10 text-white">
        <div class="mx-auto max-w-6xl">
          <p class="text-sm font-medium text-indigo-100"><a class="underline decoration-indigo-300/80 underline-offset-2 hover:text-white" href="/">← Public site</a></p>
          <div class="mt-2 flex flex-wrap items-end justify-between gap-4">
            <div>
              <h1 class="text-3xl font-bold tracking-tight">Admin console</h1>
              <p class="mt-1 text-sm text-indigo-100">
                Signed in as <strong class="text-white"><%= (typeof admin !== "undefined" && admin && admin.email) ? admin.email : "N/A" %></strong>
              </p>
            </div>
            <form method="post" action="/admin/logout">
              <button type="submit" class="rounded-xl border border-white/30 bg-white/10 px-4 py-2 text-sm font-medium backdrop-blur-sm transition hover:bg-white/20 focus:outline-none focus:ring-2 focus:ring-white/50">Log out</button>
            </form>
          </div>
        </div>
      </div>

      <div class="mx-auto max-w-6xl space-y-8 px-4 py-10">
        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-card sm:p-8">
          <div class="flex items-start gap-3">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-indigo-100 text-lg" aria-hidden="true">📅</span>
            <div class="min-w-0 flex-1">
              <h2 class="text-lg font-semibold text-slate-900">New auction round</h2>
              <p class="mt-1 text-sm text-slate-500">Bidding opens at the start of the start date and closes at <strong>11:59 PM</strong> local time on the closing date.</p>
              <form action="/admin/round" method="post" class="mt-6 grid gap-4 sm:grid-cols-2">
                <div class="sm:col-span-2">
                  <label for="round-title" class="block text-sm font-medium text-slate-700">Round title</label>
                  <input id="round-title" name="title" required class="mt-1.5 w-full rounded-xl border border-slate-300 px-3 py-2.5 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/30" placeholder="e.g. Q2 Asset Disposal" />
                </div>
                <div>
                  <label for="start-date" class="block text-sm font-medium text-slate-700">Start date (local)</label>
                  <input id="start-date" type="date" name="startDate" required class="mt-1.5 w-full rounded-xl border border-slate-300 px-3 py-2.5 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/30" />
                </div>
                <div>
                  <label for="close-date" class="block text-sm font-medium text-slate-700">Closing date (local)</label>
                  <input id="close-date" type="date" name="closeDate" required class="mt-1.5 w-full rounded-xl border border-slate-300 px-3 py-2.5 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/30" />
                </div>
                <div class="sm:col-span-2">
                  <label for="tz" class="block text-sm font-medium text-slate-700">IANA timezone</label>
                  <input id="tz" name="timezone" value="Africa/Lagos" required class="mt-1.5 w-full rounded-xl border border-slate-300 px-3 py-2.5 font-mono text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/30" />
                </div>
                <div class="sm:col-span-2">
                  <button type="submit" class="rounded-xl bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">Create round</button>
                </div>
              </form>
            </div>
          </div>
        </section>

        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-card sm:p-8">
          <div class="flex items-start gap-3">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-emerald-100 text-lg" aria-hidden="true">📄</span>
            <div class="min-w-0 flex-1">
              <h2 class="text-lg font-semibold text-slate-900">Upload assets (CSV)</h2>
              <p class="mt-1 text-sm text-slate-500">Header row optional. Columns: <code class="rounded bg-slate-100 px-1.5 py-0.5 text-xs">auction_code,name,description,location,minimum_bid</code></p>
              <form action="/admin/assets/upload" method="post" enctype="multipart/form-data" class="mt-6 grid gap-4 sm:max-w-xl">
                <div>
                  <label for="csv-round" class="block text-sm font-medium text-slate-700">Round</label>
                  <select id="csv-round" name="roundId" required class="mt-1.5 w-full rounded-xl border border-slate-300 px-3 py-2.5 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/30">
                    <option value="">Select a round…</option>
                    <% rounds.forEach(round => { %>
                    <option value="<%= round.id %>"><%= round.title %> [<%= round.status %>]</option>
                    <% }) %>
                  </select>
                </div>
                <div>
                  <label for="csv-file" class="block text-sm font-medium text-slate-700">CSV file</label>
                  <input id="csv-file" type="file" name="assetsFile" accept=".csv,text/csv" required class="mt-1.5 w-full rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm file:mr-3 file:rounded-lg file:border-0 file:bg-indigo-50 file:px-3 file:py-1.5 file:text-sm file:font-medium file:text-indigo-700" />
                </div>
                <button type="submit" class="w-fit rounded-xl bg-emerald-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2">Upload CSV</button>
              </form>
            </div>
          </div>
        </section>

        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-card sm:p-8">
          <div class="flex items-start gap-3">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-amber-100 text-lg" aria-hidden="true">✓</span>
            <div class="min-w-0 flex-1">
              <h2 class="text-lg font-semibold text-slate-900">Executive approval</h2>
              <p class="mt-1 text-sm text-slate-500">Records approval under your signed-in account. Three approvals per asset unlock winner notification.</p>
              <% if (!assets.length) { %>
              <p class="mt-4 rounded-xl border border-dashed border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">No assets yet. Create a round and upload a CSV first.</p>
              <% } else { %>
              <form method="post" action="/admin/approve" class="mt-6 grid gap-4 sm:max-w-xl">
                <div>
                  <label for="appr-round" class="block text-sm font-medium text-slate-700">Round</label>
                  <select id="appr-round" name="roundId" required class="mt-1.5 w-full rounded-xl border border-slate-300 px-3 py-2.5 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/30">
                    <% rounds.forEach(round => { %>
                    <option value="<%= round.id %>"><%= round.title %></option>
                    <% }) %>
                  </select>
                </div>
                <div>
                  <label for="appr-asset" class="block text-sm font-medium text-slate-700">Asset</label>
                  <select id="appr-asset" name="assetId" required class="mt-1.5 w-full rounded-xl border border-slate-300 px-3 py-2.5 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/30">
                    <% assets.forEach(asset => { %>
                    <option value="<%= asset.id %>"><%= asset.auction_code %> — <%= asset.name %></option>
                    <% }) %>
                  </select>
                </div>
                <button type="submit" class="w-fit rounded-xl bg-amber-500 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-amber-600 focus:outline-none focus:ring-2 focus:ring-amber-400 focus:ring-offset-2">Record my approval</button>
              </form>
              <% } %>
            </div>
          </div>
        </section>

        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-card sm:p-8">
          <h2 class="text-lg font-semibold text-slate-900">Rounds overview</h2>
          <% if (!rounds.length) { %>
          <p class="mt-4 text-sm text-slate-500">No rounds yet.</p>
          <% } else { %>
          <div class="mt-4 overflow-hidden rounded-xl border border-slate-200">
            <div class="overflow-x-auto">
              <table class="min-w-full divide-y divide-slate-200 text-sm">
                <thead class="bg-slate-50">
                  <tr>
                    <th scope="col" class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">ID</th>
                    <th scope="col" class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Title</th>
                    <th scope="col" class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Start</th>
                    <th scope="col" class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">End</th>
                    <th scope="col" class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">TZ</th>
                    <th scope="col" class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Status</th>
                    <th scope="col" class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-slate-500">Report</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                  <% rounds.forEach(round => { %>
                  <tr class="hover:bg-slate-50/80">
                    <td class="whitespace-nowrap px-4 py-3 text-slate-600"><%= round.id %></td>
                    <td class="px-4 py-3 font-medium text-slate-900"><%= round.title %></td>
                    <td class="max-w-[10rem] truncate px-4 py-3 text-slate-600" title="<%= round.start_at_local %>"><%= round.start_at_local %></td>
                    <td class="max-w-[10rem] truncate px-4 py-3 text-slate-600" title="<%= round.end_at_local %>"><%= round.end_at_local %></td>
                    <td class="whitespace-nowrap px-4 py-3 font-mono text-xs text-slate-600"><%= round.timezone %></td>
                    <td class="px-4 py-3">
                      <% if (round.status === 'OPEN') { %>
                      <span class="inline-flex rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-semibold text-emerald-800">Open</span>
                      <% } else { %>
                      <span class="inline-flex rounded-full bg-slate-200 px-2.5 py-0.5 text-xs font-semibold text-slate-700">Closed</span>
                      <% } %>
                    </td>
                    <td class="whitespace-nowrap px-4 py-3 text-right">
                      <a class="font-medium text-indigo-600 hover:underline" href="/results/<%= round.id %>">Open</a>
                    </td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
          <% } %>
        </section>

        <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-card sm:p-8">
          <div class="flex items-start gap-3">
            <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-violet-100 text-lg" aria-hidden="true">🖼️</span>
            <div class="min-w-0 flex-1">
              <h2 class="text-lg font-semibold text-slate-900">Asset images (Google Drive)</h2>
              <p class="mt-1 text-sm text-slate-500">Uploads replace the listing image URL. Configure Drive credentials in environment variables.</p>
              <% if (!assets.length) { %>
              <p class="mt-4 rounded-xl border border-dashed border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">No assets to attach images to yet.</p>
              <% } else { %>
              <div class="mt-6 space-y-4">
                <% assets.forEach(asset => { %>
                <div class="rounded-xl border border-slate-200 p-4 transition hover:border-slate-300 md:grid md:grid-cols-[1fr_auto_1fr] md:gap-4 md:items-center">
                  <div>
                    <p class="font-semibold text-slate-900"><%= asset.auction_code %></p>
                    <p class="text-sm text-slate-600 line-clamp-2"><%= asset.name %></p>
                    <p class="mt-1 text-xs text-slate-400"><%= asset.round_title %></p>
                  </div>
                  <div class="my-3 md:my-0">
                    <% if (asset.image_url) { %>
                    <img src="<%= asset.image_url %>" alt="" class="mx-auto h-24 w-full max-w-xs rounded-lg object-cover md:mx-0" loading="lazy" />
                    <% } else { %>
                    <div class="flex h-24 items-center justify-center rounded-lg border border-dashed border-slate-300 bg-slate-50 text-xs text-slate-500">No image</div>
                    <% } %>
                  </div>
                  <form action="/admin/assets/<%= asset.id %>/image" method="post" enctype="multipart/form-data" class="flex flex-col gap-2 sm:flex-row sm:items-end">
                    <input type="file" name="assetImage" accept="image/*" required class="min-w-0 flex-1 rounded-xl border border-slate-300 bg-white px-2 py-2 text-sm file:mr-2 file:rounded-lg file:border-0 file:bg-violet-50 file:px-2 file:py-1 file:text-xs file:font-medium file:text-violet-800" />
                    <button type="submit" class="shrink-0 rounded-xl bg-violet-600 px-4 py-2 text-sm font-semibold text-white hover:bg-violet-700 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:ring-offset-2">Upload</button>
                  </form>
                </div>
                <% }) %>
              </div>
              <% } %>
            </div>
          </div>
        </section>
      </div>
    </main>
  </body>
</html>
