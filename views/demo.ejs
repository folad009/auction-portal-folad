<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head', { title: 'Bidding demo', metaDescription: 'Load sample auction data and practice submitting a bid.' }) %>
  </head>
  <body class="flex min-h-screen flex-col bg-slate-50 font-sans text-slate-800 antialiased">
    <%- include('partials/nav-public', { active: 'demo' }) %>

    <main class="flex-1">
      <div class="relative overflow-hidden bg-gradient-to-br from-indigo-600 via-violet-600 to-fuchsia-600 px-4 py-12 text-white">
        <div class="pointer-events-none absolute right-0 top-0 h-72 w-72 rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
        <div class="relative mx-auto max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-wider text-indigo-100">Walkthrough</p>
          <h1 class="mt-2 text-3xl font-bold sm:text-4xl">Bidding demo</h1>
          <p class="mt-3 max-w-xl text-indigo-100/95">
            Load sample lots and pre-seeded bids, then place your own bid with a <strong>new</strong> email to see validation, ranking, and email verification.
          </p>
        </div>
      </div>

      <div class="mx-auto max-w-3xl px-4 py-10">
        <% if (flash) { %>
        <div class="mb-6 flex items-start gap-3 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-4 text-sm text-emerald-900 shadow-sm" role="status">
          <span class="text-xl" aria-hidden="true">✓</span>
          <p><%= flash %></p>
        </div>
        <% } %>

        <div class="grid gap-6 md:grid-cols-2">
          <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-card">
            <h2 class="flex items-center gap-2 text-lg font-semibold text-slate-900">
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-indigo-100 text-sm">1</span>
              Load data
            </h2>
            <p class="mt-3 text-sm text-slate-600">Creates the <strong><%= demoRoundTitle %></strong> round with two demo assets and example bids (once per database).</p>
            <% if (demoMode) { %>
            <form method="post" action="/demo/seed" class="mt-4">
              <button type="submit" class="w-full rounded-xl bg-indigo-600 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">Load demo data</button>
              <p class="mt-2 text-xs text-slate-500">Requires <code class="rounded bg-slate-100 px-1.5 py-0.5">DEMO_MODE=true</code></p>
            </form>
            <% } else { %>
            <div class="mt-4 rounded-xl border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
              Web seeding is off. Run <code class="rounded bg-amber-100 px-1.5">npm run demo:seed</code> locally, or set <code class="rounded bg-amber-100 px-1.5">DEMO_MODE=true</code>.
            </div>
            <% } %>
          </section>

          <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-card">
            <h2 class="flex items-center gap-2 text-lg font-semibold text-slate-900">
              <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-violet-100 text-sm">2</span>
              Try a bid
            </h2>
            <p class="mt-3 text-sm text-slate-600">Open a lot below. Use an email <strong>not</strong> already on that item (demo accounts are taken).</p>
            <ul class="mt-3 space-y-1 text-xs text-slate-500">
              <li><code class="rounded bg-slate-100 px-1.5 py-0.5">demo.bidder.alpha@example.com</code></li>
              <li><code class="rounded bg-slate-100 px-1.5 py-0.5">demo.bidder.beta@example.com</code></li>
            </ul>
          </section>
        </div>

        <% if (hasDemo && assets.length) { %>
        <section class="mt-10">
          <h2 class="text-lg font-semibold text-slate-900">Demo lots</h2>
          <p class="text-sm text-slate-500">Tap a card to open the asset page.</p>
          <ul class="mt-4 space-y-3">
            <% assets.forEach(a => { %>
            <li>
              <a href="/asset/<%= a.id %>" class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white p-5 shadow-card transition hover:border-indigo-200 hover:shadow-card-hover focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2">
                <div>
                  <p class="font-semibold text-slate-900"><%= a.auction_code %></p>
                  <p class="text-sm text-slate-600"><%= a.name %></p>
                </div>
                <span class="text-sm font-semibold text-indigo-600" aria-hidden="true">→</span>
              </a>
            </li>
            <% }) %>
          </ul>
        </section>
        <% } else if (!hasDemo) { %>
        <p class="mt-10 rounded-xl border border-dashed border-slate-300 bg-white p-6 text-center text-sm text-slate-600">No demo data yet. Load demo data above, then refresh this page.</p>
        <% } %>
      </div>
    </main>

    <%- include('partials/footer') %>
  </body>
</html>
