<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<% if (typeof metaDescription !== 'undefined' && metaDescription) { %>
<meta name="description" content="<%= metaDescription %>" />
<% } %>
<title><%= typeof title !== 'undefined' ? title : 'Auction Portal' %></title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
<script src="https://cdn.tailwindcss.com"></script>
<script>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: {
          sans: ["Inter", "system-ui", "sans-serif"],
        },
        boxShadow: {
          card: "0 1px 2px rgba(15, 23, 42, 0.06), 0 4px 16px rgba(15, 23, 42, 0.06)",
          "card-hover": "0 4px 12px rgba(99, 102, 241, 0.15), 0 8px 24px rgba(15, 23, 42, 0.08)",
        },
      },
    },
  };
</script>
