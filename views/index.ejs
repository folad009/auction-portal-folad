<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head', { title: 'Browse listings', metaDescription: 'View open auction assets, minimum bids, and submit electronic bids within the active window.' }) %>
  </head>
  <body class="flex min-h-screen flex-col bg-slate-50 font-sans text-slate-800 antialiased">
    <a href="#main" class="absolute left-4 top-0 z-[100] -translate-y-full rounded-b-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-md transition focus:translate-y-0">Skip to listings</a>
    <%- include('partials/nav-public', { active: 'home' }) %>

    <main id="main" class="flex-1">
      <div class="relative overflow-hidden bg-gradient-to-br from-indigo-600 via-violet-600 to-fuchsia-600 px-4 py-12 text-white">
        <div class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full bg-white/10 blur-3xl" aria-hidden="true"></div>
        <div class="pointer-events-none absolute -bottom-16 left-10 h-48 w-48 rounded-full bg-fuchsia-500/30 blur-3xl" aria-hidden="true"></div>
        <div class="relative mx-auto max-w-6xl">
          <p class="text-sm font-medium uppercase tracking-wider text-indigo-100">Open auctions</p>
          <h1 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Find an asset. Place one bid per item.</h1>
          <p class="mt-3 max-w-2xl text-indigo-100/95">Each listing shows code, location, minimum bid, and the active bidding window. Server time: <time datetime="<%= now %>"><%= now %></time></p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/demo" class="inline-flex items-center justify-center rounded-xl bg-white px-4 py-2.5 text-sm font-semibold text-indigo-700 shadow-sm transition hover:bg-indigo-50">Try the demo</a>
            <a href="/admin/login" class="inline-flex items-center justify-center rounded-xl border-2 border-white bg-white/95 px-4 py-2.5 text-sm font-semibold text-indigo-700 shadow-md transition hover:bg-white">Administrator login</a>
          </div>
          <p class="mt-4 text-xs text-indigo-100/90">Admin portal: <code class="rounded bg-black/20 px-1.5 py-0.5">/admin/login</code> or <code class="rounded bg-black/20 px-1.5 py-0.5">/login</code> (same host &amp; port as this page)</p>
        </div>
      </div>

      <div class="mx-auto max-w-6xl px-4 py-10">
        <% if (!assets.length) { %>
        <div class="rounded-2xl border border-dashed border-slate-300 bg-white p-10 text-center shadow-card">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-slate-100 text-3xl">📋</div>
          <h2 class="text-lg font-semibold text-slate-900">No open listings right now</h2>
          <p class="mx-auto mt-2 max-w-md text-sm text-slate-600">
            When an administrator publishes assets for an active round, they will appear here.
          </p>
          <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
            <a href="/demo" class="inline-flex rounded-xl bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700">Run the bidding demo</a>
            <a href="/admin/login" class="inline-flex rounded-xl border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-indigo-700 shadow-sm hover:bg-slate-50">Administrator login</a>
          </div>
        </div>
        <% } else { %>
        <div class="mb-4 flex items-end justify-between gap-4">
          <div>
            <h2 class="text-lg font-semibold text-slate-900"><%= assets.length %> asset<%= assets.length === 1 ? '' : 's' %> available</h2>
            <p class="text-sm text-slate-500">Sorted by round end time, then code.</p>
          </div>
        </div>
        <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-2 xl:grid-cols-3">
          <% assets.forEach(asset => { %>
          <li>
            <article class="group flex h-full flex-col overflow-hidden rounded-2xl border border-slate-200/80 bg-white shadow-card transition hover:border-indigo-200 hover:shadow-card-hover">
              <a href="/asset/<%= asset.id %>" class="block focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500 focus-visible:ring-offset-2">
                <% if (asset.image_url) { %>
                <div class="aspect-[16/10] overflow-hidden bg-slate-100">
                  <img src="<%= asset.image_url %>" alt="" class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]" loading="lazy" />
                </div>
                <% } else { %>
                <div class="aspect-[16/10] flex items-center justify-center bg-gradient-to-br from-slate-100 to-slate-50 text-4xl">🏷️</div>
                <% } %>
                <div class="flex flex-1 flex-col p-5">
                  <div class="flex items-start justify-between gap-2">
                    <span class="inline-flex rounded-lg bg-indigo-50 px-2 py-0.5 text-xs font-semibold text-indigo-700"><%= asset.auction_code %></span>
                    <span class="text-right text-sm font-semibold text-slate-900">Min. <%= asset.minimum_bid %></span>
                  </div>
                  <h3 class="mt-2 line-clamp-2 text-lg font-semibold text-slate-900 group-hover:text-indigo-700"><%= asset.name %></h3>
                  <p class="mt-1 line-clamp-2 text-sm text-slate-600"><%= asset.description %></p>
                  <dl class="mt-3 space-y-1 text-xs text-slate-500">
                    <div class="flex gap-1"><dt class="sr-only">Location</dt><dd>📍 <%= asset.location %></dd></div>
                    <div class="flex gap-1"><dt class="sr-only">Round</dt><dd>📁 <%= asset.round_title %></dd></div>
                  </dl>
                  <span class="mt-4 inline-flex items-center text-sm font-semibold text-indigo-600">View details & bid <span class="ml-1 transition group-hover:translate-x-0.5" aria-hidden="true">→</span></span>
                </div>
              </a>
            </article>
          </li>
          <% }) %>
        </ul>
        <% } %>
      </div>
    </main>

    <%- include('partials/footer') %>
  </body>
</html>
