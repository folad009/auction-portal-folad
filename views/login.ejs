<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('partials/head', { title: 'Administrator login', metaDescription: 'Sign in to the auction administration console. Only provisioned administrator accounts can access this area.' }) %>
  </head>
  <body class="flex min-h-screen flex-col bg-slate-50 font-sans text-slate-800 antialiased">
    <%- include('partials/nav-public', { active: 'admin' }) %>

    <main class="flex flex-1 flex-col items-center justify-center px-4 py-10">
      <div class="w-full max-w-md">
        <div class="mb-6 rounded-2xl border-2 border-indigo-200 bg-indigo-50 px-4 py-3 text-center shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-wide text-indigo-800">Admin portal</p>
          <p class="mt-1 text-sm text-indigo-900">
            Open this app at the <strong>same address</strong> as the public site (check the terminal for the port, e.g. <code class="rounded bg-white px-1 py-0.5 text-xs font-mono text-indigo-800">http://localhost:3000</code>).
          </p>
          <p class="mt-2 text-xs text-indigo-700">
            Paths: <code class="rounded bg-white px-1.5 py-0.5 font-mono">/admin/login</code> or <code class="rounded bg-white px-1.5 py-0.5 font-mono">/login</code>
          </p>
        </div>

        <div class="mb-8 text-center">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-indigo-600 to-violet-600 text-2xl font-bold text-white shadow-lg">A</div>
          <h1 class="mt-4 text-2xl font-bold text-slate-900">Administrator sign-in</h1>
          <p class="mt-2 text-sm text-slate-600">
            Only <strong>provisioned administrator accounts</strong> can access the admin console. Bidder accounts from the public site cannot sign in here.
          </p>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-8 shadow-card">
          <% if (error) { %>
          <div class="mb-6 flex gap-3 rounded-xl border border-rose-200 bg-rose-50 p-4 text-sm text-rose-800" role="alert">
            <span class="text-lg" aria-hidden="true">⚠</span>
            <div><%= error %></div>
          </div>
          <% } %>

          <form method="post" action="/admin/login" class="space-y-5" autocomplete="on">
            <div>
              <label for="login-email" class="block text-sm font-medium text-slate-700">Administrator email</label>
              <input
                id="login-email"
                type="email"
                name="email"
                required
                autocomplete="username"
                class="mt-1.5 w-full rounded-xl border border-slate-300 bg-white px-3 py-2.5 text-slate-900 shadow-sm transition focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/30"
              />
            </div>
            <div>
              <label for="login-password" class="block text-sm font-medium text-slate-700">Password</label>
              <input
                id="login-password"
                type="password"
                name="password"
                required
                autocomplete="current-password"
                class="mt-1.5 w-full rounded-xl border border-slate-300 bg-white px-3 py-2.5 text-slate-900 shadow-sm transition focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/30"
              />
            </div>
            <button
              type="submit"
              class="w-full rounded-xl bg-indigo-600 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2"
            >
              Sign in to admin
            </button>
          </form>
        </div>

        <p class="mt-6 text-center text-sm text-slate-500">
          <a class="font-medium text-indigo-600 hover:underline" href="/">← Back to public listings</a>
        </p>
      </div>
    </main>

    <%- include('partials/footer') %>
  </body>
</html>
